PORT=3000
USE_SUPABASE=true
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

ADMIN_USERNAME=admin
# ใช้แบบ hash จะปลอดภัยกว่า
# สร้าง hash ด้วยคำสั่ง: node generate-password-hash.js รหัสผ่านของคุณ
ADMIN_PASSWORD_HASH=

# ถ้ายังไม่ได้ใช้ hash จริง ๆ ค่อยใส่รหัสผ่านตรงนี้ชั่วคราว
ADMIN_PASSWORD=1234

# เปลี่ยนเป็นข้อความยาว ๆ สุ่มยาก สำหรับลงชื่อ session cookie
SESSION_SECRET=change-this-to-a-long-random-secret
